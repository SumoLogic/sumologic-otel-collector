{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["group:all"],
  "enabledManagers": ["gomod"],
  "labels": ["dependencies"],
  "recreateWhen": "always",
  "prHourlyLimit": 5,
  "commitMessagePrefix": "chore(deps):",
  "commitMessageAction": "bump",
  "commitMessageExtra": "{{depName}} from {{currentValue}} to {{newValue}}",
  "packageRules": [
    {
      "matchPackageNames": ["/.*/"],
      "enabled": false
    },
    {
      "matchPackagePatterns": [
        "^go\\.opentelemetry\\.io/collector.*$"
      ],
      "groupName": "opentelemetry-collector",
      "enabled": true
    },
    {
      "matchPackagePatterns": [
        "^github\\.com/open-telemetry/opentelemetry-collector-contrib.*$"
      ],
      "groupName": "opentelemetry-collector",
      "allowedVersions": "<2.0.0",
      "enabled": true
    },
    {
      "matchFileNames": ["pkg/extension/opampextension/go.mod"],
      "matchPackagePatterns": ["semconv"],
      "enabled": false
    },
    {
      "description": "Ignore pseudo-version pins that Renovate cannot resolve",
      "matchFileNames": ["pkg/processor/lookupprocessor/go.mod"],
      "matchPackagePatterns": ["^go\\.opentelemetry\\.io/collector.*$"],
      "enabled": false
    }
  ]
}
